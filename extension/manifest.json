{
  "manifest_version": 3,
  "name": "Neural-Janitor",
  "version": "1.0.0",
  "description": "Neural-Janitor (神经门卫) uses The Chronos Engine to learn idle patterns via Apple Core ML and clean stale tabs by category.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "notifications",
    "nativeMessaging",
    "idle",
    "sessions",
    "system.memory",
    "system.cpu"
  ],
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"],
      "run_at": "document_idle"
    }
  ]
}
